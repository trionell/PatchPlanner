# Example nginx site config for PatchPlanner.
#
# Copy to /etc/nginx/sites-available/patchplanner, replace the domain
# below with your real one, enable it, then run `certbot --nginx -d
# <domain>` — Certbot rewrites the HTTPS server block in place and adds
# the certificate paths automatically (see quickstart.md).
#
# Unlike some reverse proxies, nginx does not add X-Forwarded-Proto or
# redirect HTTP to HTTPS on its own — both are set explicitly below.
# The application's session cookie Secure flag depends on the
# X-Forwarded-Proto header reaching it (backend/internal/api/auth.go,
# requestIsSecure) — don't drop that line if you write your own config.

server {
    listen 80;
    listen [::]:80;
    server_name patchplanner.example.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name patchplanner.example.com;

    # ssl_certificate / ssl_certificate_key are added here by
    # `certbot --nginx` — left out of this example on purpose.

    location / {
        proxy_pass http://127.0.0.1:7331;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
