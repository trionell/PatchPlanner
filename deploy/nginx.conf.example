# Example nginx site config for PatchPlanner.
#
# Copy to /etc/nginx/sites-available/patchplanner, replace the domain
# below with your real one, enable it, then run `certbot --nginx -d
# <domain>` (see quickstart.md). Certbot duplicates this block into a
# new `listen 443 ssl` server block, adds the certificate paths, and
# turns this block into an HTTP->HTTPS redirect — all automatically.
#
# Only one (HTTP) server block is defined here on purpose: nginx
# refuses to start if a `listen ... ssl` block exists without
# ssl_certificate directives already pointing at real files, so an
# HTTPS block can't be included until Certbot has a certificate to
# point it at.
#
# Unlike some reverse proxies, nginx does not add X-Forwarded-Proto on
# its own. The application's session cookie Secure flag depends on the
# X-Forwarded-Proto header reaching it (backend/internal/api/auth.go,
# requestIsSecure) — don't drop that line if you write your own config.

server {
    listen 80;
    listen [::]:80;
    server_name patchplanner.example.com;

    location / {
        proxy_pass http://127.0.0.1:7331;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
